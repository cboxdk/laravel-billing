{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "cboxdk/laravel-billing",
    "description": "Cbox Billing — a self-hostable, gateway-agnostic monetization engine for Laravel: catalog, subscriptions, real-time usage metering with hard limits, a double-entry ledger, invoicing, and pricing operations.",
    "keywords": ["cbox", "billing", "subscriptions", "metering", "usage-based", "ledger", "invoicing", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/cache": "^12.0 || ^13.0",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.5 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "Cbox\\Billing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cbox\\Billing\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "pint --test",
        "analyse": "phpstan analyse --no-progress --memory-limit=1G",
        "test": "pest",
        "license-check": "@php bin/check-licenses.php",
        "sbom": "@php bin/generate-sbom.php",
        "qa": [
            "@lint",
            "@analyse",
            "@test",
            "@license-check",
            "@composer audit"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cbox\\Billing\\BillingServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
